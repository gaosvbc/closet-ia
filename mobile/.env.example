# Copy to .env and fill in to connect a real Supabase backend.
# Without these the app runs fully in mock mode with the bundled demo data.
#
#   cp .env.example .env
#
# Only EXPO_PUBLIC_* variables are exposed to the app at runtime.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the AtelIA web backend, used by the camera scan flow to call
# /api/analyze-clothing (Claude Vision). Without this set, AI analysis is
# skipped and the item form opens empty for manual entry.
EXPO_PUBLIC_API_URL=

# OpenWeather API key (free tier), used by the Hoy screen's weather widget
# and the outfit suggestion algorithm. Bundled client-side intentionally —
# it's a low-risk, rate-limited free-tier key with no user data behind it.
# Get one at https://openweathermap.org/api
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Google OAuth client ID for the "Connect Google Calendar" flow (Pro/Elite
# only). This is a public PKCE client ID, not a secret — safe to bundle
# client-side. Configure it in Google Cloud Console as an OAuth 2.0 client
# of type "iOS"/"Android" (or "Web" with the atelia:// redirect allowed).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
