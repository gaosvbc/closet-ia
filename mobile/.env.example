# Copy to .env and fill in to connect a real Supabase backend.
# Without these the app runs fully in mock mode with the bundled demo data.
#
#   cp .env.example .env
#
# Only EXPO_PUBLIC_* variables are exposed to the app at runtime.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the AtelIA web backend, used by the camera scan flow to call
# /api/analyze-clothing (Claude Vision). Without this set, AI analysis is
# skipped and the item form opens empty for manual entry.
EXPO_PUBLIC_API_URL=
