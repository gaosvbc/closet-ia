{
  "expo": {
    "name": "Visual Closet",
    "slug": "visual-closet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "closetia",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FBFAF7",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#8B1524",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.visualcloset.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We use the camera so you can scan and catalogue your wardrobe.",
        "NSPhotoLibraryUsageDescription": "We access your photos so you can add existing pictures of your clothes."
      }
    },
    "android": {
      "package": "com.visualcloset.app",
      "adaptiveIcon": {
        "backgroundColor": "#8B1524"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Visual Closet to use the camera to scan your clothes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Visual Closet to access your photos to add clothes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
