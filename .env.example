# =============================================================================
# Visual Closet Tracker — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values to enable Supabase.
# The app runs fully in fallback mode WITHOUT any of these set.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local — it is git-ignored on purpose.
# =============================================================================

# --- Supabase (public, safe to expose to the browser) -----------------------
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase service role (SERVER-ONLY — NEVER expose client-side) ----------
# This key bypasses Row Level Security. It is used only in API routes and
# server components. It must never be prefixed with NEXT_PUBLIC_ and must
# never be sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin dashboard ---------------------------------------------------------
# Password gate for the /admin route. Server-side only.
# SECURITY: use a long, random password — e.g. `openssl rand -hex 24`.
# Do NOT use a short or memorable phrase. /admin exposes personal user data
# (emails, survey responses, body-type distributions) and has no MFA.
# Failed logins are rate-limited (5 attempts → 15-min IP lockout), but a
# strong password is the primary defence.
ADMIN_PASSWORD=

# --- Claude Vision (SERVER-ONLY — NEVER expose client-side) ------------------
# Used by /api/analyze-clothing for AI clothing recognition. Get it from
# console.anthropic.com. Must never be prefixed with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# --- OpenWeather (public, free tier — safe to expose to the browser) --------
# Used by lib/weather/get-weather.ts. Low-risk, rate-limited key with no
# user data behind it, unlike the Supabase/Claude keys above.
NEXT_PUBLIC_OPENWEATHER_API_KEY=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
